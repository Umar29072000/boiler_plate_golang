# Application
APP_NAME=Fiber Boilerplate
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fiber_boilerplate
DB_SSL_MODE=disable
DB_TIMEZONE=Asia/Jakarta

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=168h

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration
# For development, use Ethereal Email (https://ethereal.email)
# For production, use Gmail, SendGrid, Mailgun, or any SMTP service
EMAIL_FROM=noreply@fiberboilerplate.com
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USERNAME=your-ethereal-username
EMAIL_PASSWORD=your-ethereal-password

# Redis Configuration (Optional - for rate limiting)
# Leave empty to use in-memory fallback
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_DURATION=15m
